---
interface Props {
  ariaLabel?: string;
}

const { ariaLabel = "Open navigation menu" } = Astro.props;
---
<span class="relative inline-block dropdown-container">
  <md-icon-button class="menu-anchor" aria-label={ariaLabel}>
    <md-icon>
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z" fill="currentColor"/>
      </svg>
    </md-icon>
  </md-icon-button>
  <md-menu class="menu-element">
    <slot />
  </md-menu>
</span>

<script>
  import '@material/web/iconbutton/icon-button.js';
  import '@material/web/icon/icon.js';
  import '@material/web/menu/menu.js';
  import '@material/web/menu/menu-item.js';

  // Dynamically query all dropdown containers and wire up the trigger button to the menu
  const containers = document.querySelectorAll('.dropdown-container');

  containers.forEach((container) => {
    const anchor = container.querySelector('.menu-anchor') as HTMLElement | null;
    // Using any for the custom element to bypass typescript typing on standard HTMLElement
    const menu = container.querySelector('.menu-element') as any;

    if (anchor && menu) {
      // Set the anchor element programmatically to avoid ID namespace collisions
      menu.anchorElement = anchor;

      anchor.addEventListener('click', () => {
        menu.open = !menu.open;
      });
    }
  });
</script>


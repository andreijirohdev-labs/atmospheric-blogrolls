---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found">
  <!-- Background glowing shapes for the atmospheric feel -->
  <div class="bg-glow-container">
    <div class="glow-bubble-1"></div>
    <div class="glow-bubble-2"></div>
  </div>

  <div class="app-container">
    <!-- Header -->
    <Header />

    <!-- Hero Area -->
    <section class="hero-section">
      <h2 class="hero-title">
        That page doesn't exist here
      </h2>
      <p class="hero-description">
        Either we're working onto that, moved around without redirects or removed for reasons.
      </p>
      
      <div class="actions-container">
        <md-filled-button href="/">
          Go back home
        </md-filled-button>
        <md-outlined-button href="https://gitlab.com/andreijiroh-dev/labs/atmospheric-blogrolls/-/issues/new" target="_blank">
          Report issue
        </md-outlined-button>
      </div>
    </section>

    <!-- Footer -->
    <Footer />
  </div>
</Layout>

<style>
  .actions-container {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  /* The Fix: Target the M3 Web Components using their specific 
    CSS Custom Properties (Design Tokens) to adjust internal padding 
  */
  md-filled-button,
  md-outlined-button {
    /* 1. Strip away any accidental global padding applied to the host tag */
    padding: 0;
    margin: 0;

    /* 2. Set the internal text spacing using M3 tokens */
    --md-filled-button-leading-space: 24px;
    --md-filled-button-trailing-space: 48px;
    --md-outlined-button-leading-space: 24px;
    --md-outlined-button-trailing-space: 48px;

    /* 3. Force a consistent minimum height so the text centers vertically */
    --md-filled-button-container-height: 48px;
    --md-outlined-button-container-height: 48px;
    
    /* 4. Ensure the text isn't overriding the M3 typography scale */
    --md-filled-button-label-text-font: 'Roboto', system-ui, sans-serif;
    --md-outlined-button-label-text-font: 'Roboto', system-ui, sans-serif;
  }
</style>

<script>
  import '@material/web/button/filled-button.js';
  import '@material/web/button/outlined-button.js';
</script>

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Listening" description="Music, podcasts and everything in between, whether it's my own mixtape playlists or someone else's setlist.">
  <!-- Background glowing shapes for the atmospheric feel -->
  <div class="bg-glow-container">
    <div class="glow-bubble-1"></div>
    <div class="glow-bubble-2"></div>
  </div>

  <div class="app-container">
    <!-- Header -->
    <Header />

    <!-- Hero Area -->
    <section class="hero-section">
      <h2 class="hero-title">
        What I have been <span class="hero-highlight">Listening</span>
      </h2>
      <p class="hero-description">
        Music, podcasts and everything in between, whether it's my own mixtape playlists or someone else's setlist.
      </p>
    </section>

    <!-- Footer -->
    <Footer />
  </div>
</Layout>
